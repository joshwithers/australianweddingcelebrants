---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import TierIcon from "@/components/TierIcon.astro";
import ProfileContactDetails from "@/components/ProfileContactDetails.astro";
import ProfileSocialLinks from "@/components/ProfileSocialLinks.astro";
import ProfileVideo from "@/components/ProfileVideo.astro";
import ProfileGallery from "@/components/ProfileGallery.astro";
import ProfileTestimonials from "@/components/ProfileTestimonials.astro";
import ProfileAwards from "@/components/ProfileAwards.astro";
import { deriveAwards } from "@/lib/utils/awards";

export async function getStaticPaths() {
  const directoryEntries = await getSinglePage("directory");

  return directoryEntries.map((entry) => {
    const slug = entry.id || slugify(entry.data?.title || "vendor");
    return {
      params: { single: slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const entrySlug = entry.id || slugify(entry.data?.title || "vendor");
const { Content } = await render(entry);
const tier = entry.data.tier || "registered";
const isPremium = tier === "endorsed" || tier === "luminary";
const websiteRel = isPremium ? "noopener" : "noopener nofollow noreferrer";

const withImagekitWidth = (url: string, width: number) => {
  if (!url.includes("imagekit.io")) return url;
  if (url.includes("?")) return url.replace(/\?tr=w-\d+/, `?tr=w-${width}`);
  return `${url}?tr=w-${width}`;
};

// Get same-tier celebrants (prefer same location, then same category)
const allVendors = await getSinglePage("directory");
const sameTierVendors = allVendors
  .filter(
    (vendor) =>
      vendor.id !== entry.id &&
      (vendor.data.tier || "registered") === tier
  );

// Prioritise same location, then same category, then random
const relatedVendors = sameTierVendors
  .sort((a, b) => {
    const aLocMatch = a.data.location.some(loc => entry.data.location.includes(loc)) ? 1 : 0;
    const bLocMatch = b.data.location.some(loc => entry.data.location.includes(loc)) ? 1 : 0;
    if (aLocMatch !== bLocMatch) return bLocMatch - aLocMatch;
    const aCatMatch = a.data.category.some(cat => entry.data.category.includes(cat)) ? 1 : 0;
    const bCatMatch = b.data.category.some(cat => entry.data.category.includes(cat)) ? 1 : 0;
    if (aCatMatch !== bCatMatch) return bCatMatch - aCatMatch;
    return Math.random() - 0.5;
  })
  .slice(0, 3);

// Tier display info
const tierInfo = {
  registered: {
    label: "Registered Celebrant",
    color: "#6a6a6a",
    borderColor: "#e0e0e0",
    bg: "#f7f7f7",
    description: "This celebrant is a Commonwealth authorised marriage celebrant on the Attorney-General's register, holds a Certificate IV in Celebrancy or equivalent qualification, and has a verified professional profile. A Registered listing means you're working with a legally authorised, qualified celebrant who has provided their professional details for your review.",
    forCouples: "You can be confident this celebrant is legally authorised to solemnise marriages in Australia. Their profile has been verified and includes their professional photo, contact details, and service information.",
  },
  endorsed: {
    label: "Endorsed Celebrant",
    color: "#92174d",
    borderColor: "#92174d",
    bg: "#fdf2f7",
    description: "This celebrant has been recognised as an Endorsed Celebrant — meaning they've submitted documented proof of at least 3 years' experience, professional indemnity insurance, ongoing professional development beyond legislative requirements, 6 or more verified reviews from couples and 3 or more from fellow wedding vendors, and 100+ ceremonies performed.",
    forCouples: "An Endorsed celebrant has gone above and beyond the basics. They've proven their commitment to the profession through years of experience, over 100 ceremonies, verified client satisfaction, and continued investment in their craft. This isn't an award — it's a recognition of documented professionalism.",
  },
  luminary: {
    label: "Luminary Celebrant",
    color: "#460479",
    borderColor: "#460479",
    bg: "#f5f0fa",
    description: "This celebrant has achieved Luminary status — the highest recognition we offer. They've submitted documented proof of at least 7 years' experience, 18+ verified reviews from couples they've married, 9+ reviews from fellow wedding vendors, industry recognition through awards or media features, and a demonstrated pattern of contribution to the celebrant profession.",
    forCouples: "A Luminary celebrant represents the very best in the profession — endorsed by both clients and industry. They've not only built an exceptional track record with 18+ verified couple reviews and 9+ vendor reviews, but have also made a measurable impact on the industry through awards, mentoring, or community contribution. This recognition celebrates their outstanding commitment to excellence.",
  },
};

const currentTierInfo = tierInfo[tier] || tierInfo.registered;

// Tier credential mapping for structured data
const tierCredentials = {
  registered: {
    name: "Registered Celebrant",
    description: "Commonwealth authorised marriage celebrant with a Certificate IV in Celebrancy or equivalent qualification and a verified professional profile",
  },
  endorsed: {
    name: "Endorsed Celebrant",
    description: "Recognised for 3+ years experience, professional indemnity insurance, ongoing professional development, 6+ verified reviews from couples and 3+ from fellow wedding vendors, and 100+ ceremonies performed",
  },
  luminary: {
    name: "Luminary Celebrant",
    description: "Highest recognition for 7+ years experience, 18+ verified reviews from couples and 9+ from fellow wedding vendors, industry awards, and demonstrated contribution to the profession",
  },
};

const currentCredential = tierCredentials[tier] || tierCredentials.registered;

// Prepare schema.org structured data
const siteUrl = "https://australianweddingcelebrants.com.au";
const imageUrl = typeof entry.data.image === 'object' && entry.data.image?.src ? entry.data.image.src : (entry.data.image || undefined);

const businessUrl = `${siteUrl}/directory/${entry.id}/`;
const sameAs = [
  entry.data.website,
  entry.data.social?.facebook,
  entry.data.social?.instagram,
  entry.data.social?.pinterest,
].filter(Boolean);

const businessSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": ["ProfessionalService", "LocalBusiness"],
  "@id": businessUrl,
  "name": entry.data.title,
  "description": entry.data.description || "",
  "url": businessUrl,
  "telephone": entry.data.phone || undefined,
  "email": entry.data.email || undefined,
  "image": imageUrl,
  "address": entry.data.address ? {
    "@type": "PostalAddress",
    "streetAddress": entry.data.address.replace(/<br\s*\/?>/gi, ', '),
    "addressCountry": "AU"
  } : undefined,
  "areaServed": entry.data.location.map(loc => ({
    "@type": "AdministrativeArea",
    "name": humanize(loc)
  })),
  "sameAs": sameAs,
  "founder": {
    "@type": "Person",
    "name": entry.data.title,
    "jobTitle": "Wedding Celebrant",
    "url": businessUrl,
    "image": imageUrl,
    "sameAs": sameAs,
  },
  "makesOffer": {
    "@type": "Offer",
    "itemOffered": {
      "@type": "Service",
      "serviceType": "Wedding Celebrant",
      "name": "Wedding Ceremony Services",
    }
  },
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "credentialCategory": "professional-recognition",
    "name": currentCredential.name,
    "description": currentCredential.description,
    "recognizedBy": {
      "@type": "Organization",
      "name": "Australian Wedding Celebrants",
      "url": siteUrl
    }
  },
  "knowsAbout": ["Wedding Ceremony", "Marriage Celebrancy", "Civil Marriage"],
};

// Clean undefined values
Object.keys(businessSchema).forEach(key => {
  if (businessSchema[key] === undefined) delete businessSchema[key];
});

// BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Directory", "item": `${siteUrl}/directory/` },
    { "@type": "ListItem", "position": 3, "name": entry.data.title },
  ]
};

// Luminary-only custom page background (hex colour).
const pageBg = tier === "luminary" ? entry.data.background_color : undefined;
---

<Base
  title={entry.data.title}
  meta_title={entry.data.meta_title}
  description={entry.data.description}
  image={typeof entry.data.image === "string" ? entry.data.image : entry.data.image?.src}
  og_type="profile"
  page_bg={pageBg}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="py-12 md:py-16" style={pageBg ? `background-color: ${pageBg};` : undefined}>
    <div class="container">
      {/* Breadcrumb */}
      <nav class="mb-8">
        <ol class="flex items-center text-sm text-light gap-2" style="font-weight: 400;">
          <li><a href="/" class="hover:text-dark no-underline">Home</a></li>
          <li class="text-border">/</li>
          <li><a href="/directory/" class="hover:text-dark no-underline">Directory</a></li>
          <li class="text-border">/</li>
          <li class="text-dark" style="font-weight: 500;">{entry.data.title}</li>
        </ol>
      </nav>

      {tier === "luminary" ? (
        <div class="luminary-hero text-center max-w-4xl mx-auto">
          {entry.data.logo ? (
            <>
              <h1 class="sr-only" set:html={markdownify(entry.data.title)} />
              <div class="flex justify-center mb-6">
                {typeof entry.data.logo === "string" ? (
                  <img
                    src={entry.data.logo}
                    alt={entry.data.title}
                    class="max-w-full max-h-48 h-auto w-auto"
                    loading="eager"
                  />
                ) : (
                  <Image
                    src={entry.data.logo}
                    alt={entry.data.title}
                    width={800}
                    class="max-w-full max-h-48 h-auto w-auto"
                    loading="eager"
                  />
                )}
              </div>
            </>
          ) : (
            <h1 class="mb-6" style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.2;" set:html={markdownify(entry.data.title)} />
          )}

          {entry.data.image && (
            <div class="luminary-hero__photo mx-auto mb-8">
              {typeof entry.data.image === "string" ? (
                <img
                  src={withImagekitWidth(entry.data.image, 1200)}
                  alt={entry.data.title}
                  loading="eager"
                />
              ) : (
                <Image
                  src={entry.data.image}
                  alt={entry.data.title}
                  widths={[480, 720, 1080, 1360]}
                  sizes="(min-width: 1024px) 680px, (min-width: 768px) 560px, 90vw"
                  loading="eager"
                  quality={90}
                />
              )}
            </div>
          )}

          <div class="flex flex-wrap justify-center gap-2 mb-6">
            <a href="/luminaries/" class="pill-luminary inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm no-underline transition-all" style="font-weight: 600;">
              <TierIcon tier="luminary" size={14} />
              Luminary Celebrant
            </a>
            {entry.data.australia_wide && (
              <a href="/australia-wide/" class="pill-dark inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm no-underline transition-all" style="font-weight: 500;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                Travels Australia Wide
              </a>
            )}
            {entry.data.international && (
              <a href="/destination-wedding-celebrants/" class="pill-dark inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm no-underline transition-all" style="font-weight: 500;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path d="M7 3.34V5a3 3 0 0 0 3 3a2 2 0 0 1 2 2c0 1.1.9 2 2 2a2 2 0 0 0 2-2c0-1.1.9-2 2-2h3.17"/><path d="M11 21.95V18a2 2 0 0 0-2-2a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/></svg>
                Destination Weddings
              </a>
            )}
          </div>

          {entry.data.description && (
            <p class="text-light text-lg max-w-2xl mx-auto mb-8" style="font-weight: 400; line-height: 1.6;">
              {entry.data.description}
            </p>
          )}

          <div class="mb-6">
            <ProfileContactDetails
              location={entry.data.location}
              website={entry.data.website}
              email={entry.data.email}
              phone={entry.data.phone}
              address={entry.data.address}
              tier={tier}
              centered
            />
          </div>

          {entry.data.social && (
            <div class="flex justify-center mb-6">
              <ProfileSocialLinks
                facebook={entry.data.social.facebook}
                instagram={entry.data.social.instagram}
                pinterest={entry.data.social.pinterest}
              />
            </div>
          )}

          <div class="flex flex-wrap justify-center gap-3">
            {entry.data.website && (
              <a href={entry.data.website} target="_blank" rel={websiteRel} class="btn btn-primary no-underline">
                Visit Website
              </a>
            )}
            {entry.data.email && (
              <a href={`mailto:${entry.data.email}`} class="btn btn-outline-primary no-underline">
                Get in Touch
              </a>
            )}
          </div>

        </div>
      ) : (
        <div class="flex flex-wrap items-start gap-10">
          {entry.data.image && (
            <div class="w-full md:w-[calc(50%-1.25rem)] lg:w-[calc(60%-1.25rem)]">
              <div class="rounded-card overflow-hidden" style="box-shadow: rgba(0,0,0,0.02) 0px 0px 0px 1px, rgba(0,0,0,0.04) 0px 2px 6px, rgba(0,0,0,0.1) 0px 4px 8px;">
                {typeof entry.data.image === "string" ? (
                  <img
                    src={withImagekitWidth(entry.data.image, 600)}
                    alt={entry.data.title}
                    width={600}
                    height={600}
                    class="profile-hero-img w-full"
                    loading="eager"
                  />
                ) : (
                  <Image
                    src={entry.data.image}
                    alt={entry.data.title}
                    width={600}
                    height={600}
                    class="profile-hero-img w-full"
                    loading="eager"
                  />
                )}
              </div>
            </div>
          )}

          <div class={entry.data.image ? "flex-1 min-w-0" : "w-full max-w-2xl mx-auto"}>
            <div class="mb-6">
              {entry.data.logo && isPremium ? (
                <div class="mb-4">
                  {typeof entry.data.logo === "string" ? (
                    <img
                      src={entry.data.logo}
                      alt={entry.data.title}
                      class="max-w-full max-h-48 h-auto w-auto"
                      loading="eager"
                    />
                  ) : (
                    <Image
                      src={entry.data.logo}
                      alt={entry.data.title}
                      width={800}
                      class="max-w-full max-h-48 h-auto w-auto"
                      loading="eager"
                    />
                  )}
                </div>
              ) : (
                <h1 style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.2;" set:html={markdownify(entry.data.title)} />
              )}

              <div class="flex flex-wrap gap-2 mt-3">
                {tier === "endorsed" && (
                  <a href="/endorsed/" class="pill-endorsed inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm no-underline transition-all" style="font-weight: 600;">
                    <TierIcon tier="endorsed" size={14} />
                    Endorsed Celebrant
                  </a>
                )}
                {tier === "registered" && (
                  <a href="/registered/" class="inline-flex items-center gap-2 text-light px-3 py-1 rounded-full text-sm border border-border no-underline hover:bg-theme-light hover:text-dark transition-all" style="font-weight: 500;">
                    Registered Celebrant
                  </a>
                )}
                {entry.data.australia_wide && (
                  <a href="/australia-wide/" class="pill-dark inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm no-underline transition-all" style="font-weight: 500;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    Travels Australia Wide
                  </a>
                )}
                {entry.data.international && (
                  <a href="/destination-wedding-celebrants/" class="pill-dark inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm no-underline transition-all" style="font-weight: 500;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path d="M7 3.34V5a3 3 0 0 0 3 3a2 2 0 0 1 2 2c0 1.1.9 2 2 2a2 2 0 0 0 2-2c0-1.1.9-2 2-2h3.17"/><path d="M11 21.95V18a2 2 0 0 0-2-2a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/></svg>
                    Destination Weddings
                  </a>
                )}
              </div>

              {entry.data.description && (
                <p class="mt-4 text-light text-base" style="font-weight: 400; line-height: 1.6;">
                  {entry.data.description}
                </p>
              )}
            </div>

            <div class="mb-6">
              <ProfileContactDetails
                location={entry.data.location}
                website={entry.data.website}
                email={entry.data.email}
                phone={entry.data.phone}
                address={entry.data.address}
              />
            </div>

            {entry.data.social && (
              <div class="mt-6">
                <ProfileSocialLinks
                  facebook={entry.data.social.facebook}
                  instagram={entry.data.social.instagram}
                  pinterest={entry.data.social.pinterest}
                />
              </div>
            )}

            <div class="flex flex-wrap gap-3 mt-8">
              {entry.data.website && (
                <a href={entry.data.website} target="_blank" rel={websiteRel} class="btn btn-primary no-underline">
                  Visit Website
                </a>
              )}
              {entry.data.email && (
                <a href={`mailto:${entry.data.email}`} class="btn btn-outline-primary no-underline">
                  Get in Touch
                </a>
              )}
            </div>

          </div>
        </div>
      )}

      {/* Content body */}
      {entry.body && (
        <div class="content mt-16 pt-12 border-t border-border max-w-3xl mx-auto">
          {entry.data.logo && tier === "endorsed" && (
            <h1 class="mb-6" style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.2;" set:html={markdownify(entry.data.title)} />
          )}
          <Content />
        </div>
      )}

      {/* YouTube feature video */}
      {entry.data.youtube && (
        <div class="mt-16 max-w-4xl mx-auto">
          <ProfileVideo url={entry.data.youtube} title={`Meet ${entry.data.title}`} />
        </div>
      )}

      {/* Gallery */}
      {entry.data.gallery && entry.data.gallery.length > 0 && (
        <div class="mt-12 max-w-5xl mx-auto">
          <ProfileGallery images={entry.data.gallery} alt={`Work by ${entry.data.title}`} />
        </div>
      )}

      {/* Luminary + Endorsed: testimonials */}
      {(tier === "luminary" || tier === "endorsed") && entry.data.testimonials && entry.data.testimonials.length > 0 && (
        <div class="mt-16 max-w-5xl mx-auto">
          <ProfileTestimonials testimonials={entry.data.testimonials} subjectName={entry.data.title} />
        </div>
      )}

      {/* Awards — trophy shelf of regional + fun recognitions */}
      {(() => {
        const shelf = deriveAwards(entry.data);
        return shelf.length > 0 ? (
          <div class="mt-16 max-w-5xl mx-auto">
            <ProfileAwards awards={shelf} subjectName={entry.data.title} subjectSlug={entrySlug} />
          </div>
        ) : null;
      })()}

      {/* Tier info box */}
      <div class="mt-20 pt-12">
        <div class="rounded-card p-8 md:p-10" style={`border: 2px solid ${currentTierInfo.borderColor}; background: ${currentTierInfo.bg};`}>
          <div class="flex flex-col md:flex-row md:items-start gap-6">
            <div class="flex-none">
              {tier === "luminary" && (
                <div class="inline-flex items-center gap-2 text-white px-4 py-1.5 rounded-full text-sm" style="font-weight: 600; background: #460479;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                  Luminary
                </div>
              )}
              {tier === "endorsed" && (
                <div class="inline-flex items-center gap-2 text-white px-4 py-1.5 rounded-full text-sm" style="font-weight: 600; background: #92174d;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                  Endorsed
                </div>
              )}
              {tier === "registered" && (
                <div class="inline-flex items-center gap-2 text-light px-4 py-1.5 rounded-full text-sm border border-border" style="font-weight: 500;">
                  Registered
                </div>
              )}
            </div>
            <div>
              <h2 class="text-base mb-2 text-dark" style="font-weight: 600; letter-spacing: -0.18px;">
                What does {currentTierInfo.label} mean for you?
              </h2>
              <p class="text-sm text-dark mb-3" style="font-weight: 400; line-height: 1.6;">
                {currentTierInfo.forCouples}
              </p>
              <a href="/tiers/" class="text-sm no-underline hover:underline" style={`color: ${currentTierInfo.color}; font-weight: 500;`}>
                Learn more about our standards
              </a>
            </div>
          </div>
        </div>
      </div>

      {/* Celebrant tools — embed badge + edit listing (for profile owners) */}
      <div class="mt-16 pt-12">
        <details class="group">
          <summary class="cursor-pointer list-none flex items-center gap-3 text-sm text-light hover:text-dark transition-colors duration-200" style="font-weight: 500;">
            <svg class="w-5 h-5 transition-transform duration-200 group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Is this your listing? Edit it or grab your badge
          </summary>
          <div class="mt-6 space-y-6">
            {/* Edit listing */}
            <div class="flex items-start gap-4">
              <svg class="w-5 h-5 text-light flex-none mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 20h9" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <div class="flex-1">
                <h3 class="text-sm text-dark mb-1" style="font-weight: 600;">Manage your profile</h3>
                <p class="text-sm text-light mb-2" style="font-weight: 400; line-height: 1.6;">
                  Sign in to update your photos, bio, contact details and more.
                </p>
                <a
                  href={`https://api.australianweddingcelebrants.com.au/login?slug=${entrySlug}`}
                  class="text-sm text-dark hover:text-primary no-underline hover:underline"
                  style="font-weight: 500;"
                >
                  Edit this listing →
                </a>
              </div>
            </div>

            <div class="border-t border-border"></div>

            <h3 class="text-sm text-dark" style="font-weight: 600;">Embed your tier badge</h3>
            <p class="text-sm text-light" style="font-weight: 400; line-height: 1.6;">
              Copy this code and paste it into your website to display your Australian Wedding Celebrants tier badge.
            </p>

            {/* Badge preview */}
            <div class="p-6 bg-theme-light rounded-card flex justify-center">
              <div style={`display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:50px;font-family:Inter,-apple-system,system-ui,sans-serif;font-size:13px;font-weight:600;text-decoration:none;transition:opacity 0.2s;${
                tier === "luminary" ? "background:#460479;color:#fff;" :
                tier === "endorsed" ? "background:#92174d;color:#fff;" :
                "background:#f7f7f7;color:#6a6a6a;border:1px solid #e0e0e0;"
              }`}>
                {tier === "luminary" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                )}
                {tier === "endorsed" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                )}
                {currentTierInfo.label}
              </div>
            </div>

            {/* Code block */}
            <div class="relative">
              <pre class="bg-dark text-white rounded-card p-5 text-xs overflow-x-auto" style="line-height: 1.6;"><code id="embedCode" set:html={
                tier === "luminary"
                  ? `&lt;a href=&quot;https://australianweddingcelebrants.com.au/directory/${entrySlug}/&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot; style=&quot;display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:50px;background:#460479;color:#fff;font-family:Inter,-apple-system,system-ui,sans-serif;font-size:13px;font-weight:600;text-decoration:none;transition:opacity 0.2s;&quot; onmouseover=&quot;this.style.opacity='0.85'&quot; onmouseout=&quot;this.style.opacity='1'&quot;&gt;&lt;svg width=&quot;16&quot; height=&quot;16&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot;&gt;&lt;path d=&quot;M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z&quot;/&gt;&lt;/svg&gt;Luminary Celebrant&lt;/a&gt;`
                  : tier === "endorsed"
                  ? `&lt;a href=&quot;https://australianweddingcelebrants.com.au/directory/${entrySlug}/&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot; style=&quot;display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:50px;background:#92174d;color:#fff;font-family:Inter,-apple-system,system-ui,sans-serif;font-size:13px;font-weight:600;text-decoration:none;transition:opacity 0.2s;&quot; onmouseover=&quot;this.style.opacity='0.85'&quot; onmouseout=&quot;this.style.opacity='1'&quot;&gt;&lt;svg width=&quot;16&quot; height=&quot;16&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot;&gt;&lt;path d=&quot;M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z&quot;/&gt;&lt;/svg&gt;Endorsed Celebrant&lt;/a&gt;`
                  : `&lt;a href=&quot;https://australianweddingcelebrants.com.au/directory/${entrySlug}/&quot; target=&quot;_blank&quot; rel=&quot;noopener&quot; style=&quot;display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:50px;background:#f7f7f7;color:#6a6a6a;border:1px solid #e0e0e0;font-family:Inter,-apple-system,system-ui,sans-serif;font-size:13px;font-weight:600;text-decoration:none;transition:opacity 0.2s;&quot; onmouseover=&quot;this.style.opacity='0.85'&quot; onmouseout=&quot;this.style.opacity='1'&quot;&gt;Registered Celebrant&lt;/a&gt;`
              } /></pre>
              <button
                id="copyBtn"
                class="absolute top-3 right-3 px-3 py-1.5 rounded-btn text-xs bg-white/10 text-white/70 hover:bg-white/20 hover:text-white transition-all duration-200"
                style="font-weight: 500;"
                type="button"
              >
                Copy
              </button>
            </div>
          </div>
        </details>
      </div>

      {/* Same-tier celebrants */}
      {relatedVendors.length > 0 && (
        <div class="mt-16 pt-12 border-t border-border">
          <h2 class="mb-10" style="font-weight: 600; letter-spacing: -0.44px;">
            More {currentTierInfo.label}s
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedVendors.map((vendor) => {
              const vendorTier = vendor.data.tier || "registered";
              const vendorSlug = vendor.id || slugify(vendor.data?.title || "vendor");
              return (
                <div>
                  <a href={`/directory/${vendorSlug}/`} class="group block no-underline">
                    <div class="rounded-card overflow-hidden bg-white transition-shadow duration-300 hover:shadow-card-hover" style="box-shadow: rgba(0,0,0,0.02) 0px 0px 0px 1px, rgba(0,0,0,0.04) 0px 2px 6px, rgba(0,0,0,0.1) 0px 4px 8px;">
                      {vendor.data.image && (
                        <div class="relative overflow-hidden">
                          {typeof vendor.data.image === "string" ? (
                            <img
                              src={withImagekitWidth(vendor.data.image, 400)}
                              alt={vendor.data.title}
                              loading="lazy"
                              class="related-card-img w-full group-hover:scale-[1.03] transition-transform duration-500"
                            />
                          ) : (
                            <Image
                              src={vendor.data.image}
                              alt={vendor.data.title}
                              width={400}
                              loading="lazy"
                              class="related-card-img w-full group-hover:scale-[1.03] transition-transform duration-500"
                            />
                          )}
                          {vendorTier === "luminary" && (
                            <span class="absolute top-3 left-3 text-white px-3 py-1 rounded-badge text-xs flex items-center gap-1.5" style="font-weight: 600; background: #460479; backdrop-filter: blur(4px);">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                              Luminary
                            </span>
                          )}
                          {vendorTier === "endorsed" && (
                            <span class="absolute top-3 left-3 text-white px-3 py-1 rounded-badge text-xs flex items-center gap-1.5" style="font-weight: 600; background: #92174d; backdrop-filter: blur(4px);">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                              Endorsed
                            </span>
                          )}
                          {vendorTier === "registered" && (
                            <span class="absolute top-3 left-3 px-3 py-1 rounded-badge text-xs" style="font-weight: 500; background: rgba(255,255,255,0.9); color: #6a6a6a; backdrop-filter: blur(4px);">
                              Registered
                            </span>
                          )}
                        </div>
                      )}
                      <div class="p-4">
                        <h3 class="text-base mb-1 text-dark" style="font-weight: 600; letter-spacing: -0.18px;">{vendor.data.title}</h3>
                        {vendor.data.location && vendor.data.location.length > 0 && (
                          <p class="text-sm text-light mb-1" style="font-weight: 400;">{vendor.data.location.map((loc) => humanize(loc)).join(" · ")}</p>
                        )}
                        {vendor.data.description && (
                          <p class="text-sm text-light mb-3 line-clamp-2" style="font-weight: 400;">{vendor.data.description}</p>
                        )}
                        <div class="flex flex-wrap gap-1.5">
                          {vendor.data.category.map((cat) => (
                            <span class="bg-theme-light text-dark px-2 py-0.5 rounded-badge text-xs" style="font-weight: 500;">
                              {humanize(cat)}
                            </span>
                          ))}
                          {vendor.data.australia_wide && (
                            <span class="text-white px-2 py-0.5 rounded-badge text-xs flex items-center gap-1" style="font-weight: 500; background: #222;">
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                              Australia Wide
                            </span>
                          )}
                          {vendor.data.international && (
                            <span class="text-white px-2 py-0.5 rounded-badge text-xs flex items-center gap-1" style="font-weight: 500; background: #222;">
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path d="M7 3.34V5a3 3 0 0 0 3 3a2 2 0 0 1 2 2c0 1.1.9 2 2 2a2 2 0 0 0 2-2c0-1.1.9-2 2-2h3.17"/><path d="M11 21.95V18a2 2 0 0 0-2-2a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/></svg>
                              Destination
                            </span>
                          )}
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Back to directory */}
      <div class="text-center mt-16">
        <a href="/directory/" class="btn btn-outline-primary no-underline">Back to Directory</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .profile-hero-img {
    height: auto !important;
    max-height: none !important;
  }

  .related-card-img {
    height: auto !important;
    width: 100%;
  }

  /* Luminary hero — large centered photo with a soft frame */
  .luminary-hero__photo {
    width: min(420px, 90%);
    border-radius: 24px;
    overflow: hidden;
    box-shadow:
      rgba(70, 4, 121, 0.08) 0px 0px 0px 1px,
      rgba(0, 0, 0, 0.06) 0px 8px 24px,
      rgba(0, 0, 0, 0.08) 0px 16px 40px;
  }

  @media (min-width: 768px) {
    .luminary-hero__photo {
      width: min(560px, 80%);
    }
  }

  @media (min-width: 1024px) {
    .luminary-hero__photo {
      width: min(680px, 75%);
    }
  }

  .luminary-hero__photo :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('copyBtn');
    const code = document.getElementById('embedCode');
    if (!btn || !code) return;
    btn.addEventListener('click', () => {
      const text = code.textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });
</script>
