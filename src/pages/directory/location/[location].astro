---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { humanize, plainify, slugify, truncateText } from "@/lib/utils/textConverter";
import MasonryGrid from "@/components/MasonryGrid.astro";
import LocationMap from "@/components/LocationMap.astro";
import { getEntry, render, type CollectionEntry } from "astro:content";
import config from "@/config/config.json";

export async function getStaticPaths() {
  const directoryItems = await getSinglePage("directory");

  const locations = [
    ...new Set(
      directoryItems.flatMap((item) => item.data.location)
    ),
  ];

  return locations.map((location) => {
    return {
      params: { location: slugify(location) },
      props: { location, directoryItems },
    };
  });
}

const { location, directoryItems } = Astro.props as {
  location: string;
  directoryItems: CollectionEntry<"directory">[];
};

// Filter vendors by the current location OR australia_wide flag
const filteredVendors = directoryItems.filter((item) =>
  item.data.location.some((loc) => slugify(loc) === slugify(location)) ||
  item.data.australia_wide === true
);

// Fisher-Yates shuffle first for fair random base ordering
const vendors = [...filteredVendors];
for (let i = vendors.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [vendors[i], vendors[j]] = [vendors[j], vendors[i]];
}

// Sort vendors by an explicit priority:
//   0. Luminary, local
//   1. Endorsed, local
//   2. Luminary, travels Australia-wide (non-local)
//   3. Registered, local
//   4. Endorsed, travels Australia-wide (non-local)
//   5. Registered, travels Australia-wide (non-local)
const isLocal = (item: CollectionEntry<"directory">) =>
  item.data.location.some((loc: string) => slugify(loc) === slugify(location));
const rankOf = (item: CollectionEntry<"directory">) => {
  const tier = item.data.tier || "registered";
  const local = isLocal(item);
  if (tier === "luminary"   && local)  return 0;
  if (tier === "endorsed"   && local)  return 1;
  if (tier === "luminary"   && !local) return 2;
  if (tier === "registered" && local)  return 3;
  if (tier === "endorsed"   && !local) return 4;
  return 5; // registered, non-local
};
// Within each rank bucket, push celebrants with more explicit awards higher.
// The stable sort keeps the Fisher–Yates shuffle as a final tiebreaker.
// Synthetic "Class of {year}" entries aren't counted — everyone has one.
const awardCount = (item: CollectionEntry<"directory">) =>
  Array.isArray(item.data.awards) ? item.data.awards.length : 0;
vendors.sort((a, b) => {
  const rankDiff = rankOf(a) - rankOf(b);
  if (rankDiff !== 0) return rankDiff;
  return awardCount(b) - awardCount(a);
});

// Optional SEO blurb — generated by scripts/generate-location-blurbs.mjs.
// Hand-edit src/content/location-blurbs/<slug>.md to override.
const blurbEntry = await getEntry("locationBlurbs", slugify(location));
const BlurbContent = blurbEntry ? (await render(blurbEntry)).Content : null;

const humanLocation = humanize(location);
const pageTitle = `The Top ${vendors.length} Wedding Celebrants in ${humanLocation}`;

// Per-page meta description: prefer the blurb's opening sentence; fall back to
// a generated string when no blurb exists yet.
const metaDescription = blurbEntry
  ? truncateText(plainify(blurbEntry.body || "").replace(/\s+/g, " ").trim(), 155)
  : `Browse ${vendors.length} wedding celebrants serving ${humanLocation}. Verified profiles, contact details, and the right marriage celebrant for your wedding day.`;

const siteUrl = config.site.base_url;
const pageUrl = `${siteUrl}/directory/location/${slugify(location)}/`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Directory", "item": `${siteUrl}/directory/` },
    { "@type": "ListItem", "position": 3, "name": humanLocation, "item": pageUrl },
  ],
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": metaDescription,
  "url": pageUrl,
  "inLanguage": "en-AU",
  "isPartOf": { "@type": "WebSite", "name": config.site.title, "url": siteUrl },
  "about": {
    "@type": "Place",
    "name": `${humanLocation}, Australia`,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": humanLocation,
      "addressCountry": "AU",
    },
  },
  "mainEntity": {
    "@type": "ItemList",
    "name": pageTitle,
    "numberOfItems": vendors.length,
    "itemListOrder": "https://schema.org/ItemListOrderAscending",
    "itemListElement": vendors.map((vendor, i) => {
      const slug = vendor.id || slugify(vendor.data?.title || "vendor");
      const item: Record<string, any> = {
        "@type": "ListItem",
        "position": i + 1,
        "url": `${siteUrl}/directory/${slug}/`,
        "name": vendor.data.title,
      };
      const img = vendor.data.image;
      if (typeof img === "string") {
        item.image = img;
      } else if (img && typeof img === "object" && "src" in img) {
        item.image = `${siteUrl}${(img as { src: string }).src}`;
      }
      return item;
    }),
  },
};
---

<Base title={pageTitle} description={metaDescription}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />

  <section class="py-12 md:py-16">
    <div class="container">
      {/* Breadcrumb */}
      <nav class="mb-8">
        <ol class="flex items-center text-sm text-light gap-2" style="font-weight: 400;">
          <li><a href="/" class="hover:text-dark no-underline">Home</a></li>
          <li class="text-border">/</li>
          <li><a href="/directory/" class="hover:text-dark no-underline">Directory</a></li>
          <li class="text-border">/</li>
          <li class="text-dark" style="font-weight: 500;">{humanize(location)}</li>
        </ol>
      </nav>

      {/* Page header */}
      <div class="text-center mb-12">
        <h1 class="mb-4" style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.2;">
          The Top {vendors.length} Wedding Celebrants in {humanize(location)}
        </h1>
        <p class="text-light text-base" style="font-weight: 400;">
          Discover the best wedding celebrants available in {humanize(location)}
        </p>
      </div>

      {BlurbContent && (
        <div class="location-blurb max-w-3xl mx-auto mb-12 text-light text-base" style="font-weight: 400; line-height: 1.7;">
          <BlurbContent />
        </div>
      )}

      {vendors.length > 0 ? (
        <MasonryGrid items={vendors} />
      ) : (
        <div class="text-center py-16">
          <p class="text-light text-lg">No celebrants found in this location.</p>
        </div>
      )}

      {/* Map of the region — click-to-load facade. Helps with regional context for users
          and gives the page another locally-grounded asset for search engines. */}
      <div class="mt-16 max-w-5xl mx-auto">
        <h2 class="text-center mb-6 text-dark" style="font-weight: 600; letter-spacing: -0.18px;">
          {humanLocation} on the map
        </h2>
        <LocationMap location={humanLocation} />
      </div>

      <div class="text-center mt-12">
        <a href="/directory/" class="btn btn-outline-primary no-underline">Back to Directory</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .location-blurb :global(p + p) {
    margin-top: 1.1em;
  }
</style>
