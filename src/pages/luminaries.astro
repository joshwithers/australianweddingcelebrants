---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import DirectoryItem from "@/components/DirectoryItem.astro";

const allItems = await getSinglePage("directory");
const items = allItems
  .filter(item => (item.data.tier || "registered") === "luminary");
// Fisher-Yates shuffle for fair random ordering
for (let i = items.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [items[i], items[j]] = [items[j], items[i]];
}
---

<Base title="Luminary Celebrants" meta_title="Luminary Celebrants — Australian Wedding Celebrants" description="Meet our Luminary celebrants — the very best in the profession with 7+ years experience, 20+ couple reviews, 10+ vendor reviews, and recognised industry contribution.">
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 text-white px-4 py-1.5 rounded-full text-sm mb-4" style="font-weight: 600; background: #460479;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
          Luminary
        </div>
        <h1 class="mb-4" style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.2;">
          Luminary Celebrants
        </h1>
        <p class="text-light max-w-2xl mx-auto" style="font-weight: 400; line-height: 1.6;">
          The highest recognition we offer. These celebrants have demonstrated 7+ years of experience, 20+ couple reviews, 10+ vendor reviews, industry awards, and a measurable contribution to the profession. {items.length} celebrants recognised.
        </p>
      </div>

      <div class="masonry-grid">
        {items.map((item, index) => (
          <DirectoryItem item={item} isFirst={index === 0} />
        ))}
      </div>

      {items.length === 0 && (
        <div class="text-center py-16">
          <p class="text-light text-lg">No luminary celebrants yet. <a href="/contact/" class="text-dark underline">Submit your documentation</a> to be the first.</p>
        </div>
      )}

      <div class="text-center mt-12">
        <a href="/directory/" class="btn btn-outline-primary no-underline">View All Celebrants</a>
      </div>
    </div>
  </section>
</Base>
