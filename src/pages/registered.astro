---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import DirectoryItem from "@/components/DirectoryItem.astro";

const allItems = await getSinglePage("directory");
const items = allItems
  .filter(item => (item.data.tier || "registered") === "registered")
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Base title="Registered Celebrants" meta_title="Registered Celebrants — Australian Wedding Celebrants" description="Browse all Registered celebrants in our directory. Every celebrant listed is a Commonwealth authorised marriage celebrant with a verified professional profile.">
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 text-light px-4 py-1.5 rounded-full text-sm border border-border mb-4" style="font-weight: 500;">
          Registered
        </div>
        <h1 class="mb-4" style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.2;">
          Registered Celebrants
        </h1>
        <p class="text-light max-w-2xl mx-auto" style="font-weight: 400; line-height: 1.6;">
          Every celebrant here is a Commonwealth authorised marriage celebrant on the Attorney-General's register, with a verified professional profile. {items.length} celebrants listed.
        </p>
      </div>

      <div class="masonry-grid">
         {items.map((item, index) => (
           <DirectoryItem item={item} isFirst={index === 0} />
         ))}
       </div>

      {items.length === 0 && (
        <div class="text-center py-16">
          <p class="text-light text-lg">No registered celebrants found.</p>
        </div>
      )}

      <div class="text-center mt-12">
        <a href="/directory/" class="btn btn-outline-primary no-underline">View All Celebrants</a>
      </div>
    </div>
  </section>
</Base>
