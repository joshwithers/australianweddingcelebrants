---
import Base from "../layouts/Base.astro";
---

<Base title="Page Not Found" noindex={true}>
  <section class="error-page">
    <div class="error-bg" aria-hidden="true">
      {/* Animated rings */}
      <div class="ring ring-1"></div>
      <div class="ring ring-2"></div>
      <div class="ring ring-3"></div>

      {/* Floating petals */}
      <div class="petal petal-1"></div>
      <div class="petal petal-2"></div>
      <div class="petal petal-3"></div>
      <div class="petal petal-4"></div>
      <div class="petal petal-5"></div>
      <div class="petal petal-6"></div>
      <div class="petal petal-7"></div>
      <div class="petal petal-8"></div>
    </div>

    <div class="container relative z-10">
      <div class="error-content">
        <div class="error-number" id="errorNum" title="Try clicking me...">404</div>
        <h1 class="error-title" id="errorTitle">This page wandered off</h1>
        <p class="error-subtitle" id="errorSub">Like a guest who can't find the ceremony venue, the page you're looking for seems to have taken a wrong turn.</p>
        <div class="error-actions">
          <a href="/" class="btn btn-primary px-8 py-3 no-underline">Take Me Home</a>
          <a href="/directory/" class="btn btn-outline-primary px-8 py-3 no-underline">Find a Celebrant</a>
        </div>
        <p class="vow-counter" id="vowCounter"></p>
      </div>
    </div>

    <script is:inline>
      (function() {
        var num = document.getElementById('errorNum');
        var title = document.getElementById('errorTitle');
        var sub = document.getElementById('errorSub');
        var counter = document.getElementById('vowCounter');
        if (!num || !title || !sub || !counter) return;

        var clicks = 0;

        var stages = [
          null,
          { t: "This page wandered off", s: "Like a guest who can't find the ceremony venue, the page you're looking for seems to have taken a wrong turn.", c: "" },
          { t: "Still here?", s: "Most people would have left by now. But you're committed. We respect that.", c: "" },
          { t: "Okay, you're persistent", s: "That's a quality we look for in a good celebrant, actually.", c: "" },
          { t: "Do you take this 404...", s: "...to be your lawfully wedded error page, in sickness and in health, in broken links and redirects?", c: "" },
          { t: "I do", s: "Beautiful. Now let's exchange the vows.", c: "Vow 1 of 4: To always return to the homepage when lost" },
          { t: "I do", s: "Lovely. Keep going.", c: "Vow 2 of 4: To never blame the celebrant when a page goes missing" },
          { t: "I do", s: "Almost there...", c: "Vow 3 of 4: To browse the directory at least once a week" },
          { t: "I do", s: "By the power vested in me by this 404 page...", c: "Vow 4 of 4: To tell all my friends about Australian Wedding Celebrants" },
          { t: "I now pronounce you...", s: "...officially lost. But also married to this error page. Congratulations. You may kiss the screen.", c: "\uD83C\uDF89 Certificate of Marriage to Error 404 \u2014 witnessed by 0 guests and 8 floating petals" },
          { t: "You're still clicking?!", s: "The ceremony is over. Go home. Or find a celebrant. Or keep clicking. We're not your mum.", c: "Clicks beyond the ceremony: 1" }
        ];

        num.addEventListener('click', function() {
          clicks++;
          num.classList.remove('wiggle', 'vowed');
          void num.offsetWidth;

          if (clicks < stages.length) {
            var st = stages[clicks];
            if (st) {
              title.textContent = st.t;
              sub.textContent = st.s;
              if (st.c) {
                counter.textContent = st.c;
                counter.classList.add('visible');
              }
              if (clicks >= 4) {
                num.classList.add('vowed');
              } else {
                num.classList.add('wiggle');
              }
            }
          } else {
            var overflow = clicks - stages.length + 1;
            counter.textContent = 'Clicks beyond the ceremony: ' + overflow + '... seriously, go find a celebrant.';
            num.classList.add('wiggle');
          }
        });
      })();
    </script>
  </section>
</Base>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: #fff;
  }

  .error-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Interlocking wedding rings — slowly rotating */
  .ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid;
  }

  .ring-1 {
    width: 55vmin;
    height: 55vmin;
    top: 50%;
    left: 50%;
    transform: translate(-60%, -50%);
    border-color: rgba(34, 34, 34, 0.04);
    animation: ring-spin 60s linear infinite;
  }

  .ring-2 {
    width: 55vmin;
    height: 55vmin;
    top: 50%;
    left: 50%;
    transform: translate(-40%, -50%);
    border-color: rgba(255, 56, 92, 0.06);
    animation: ring-spin-reverse 50s linear infinite;
  }

  .ring-3 {
    width: 80vmin;
    height: 80vmin;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-color: rgba(34, 34, 34, 0.02);
    animation: ring-spin 90s linear infinite;
  }

  @keyframes ring-spin {
    from { transform: translate(-60%, -50%) rotate(0deg); }
    to { transform: translate(-60%, -50%) rotate(360deg); }
  }

  @keyframes ring-spin-reverse {
    from { transform: translate(-40%, -50%) rotate(0deg); }
    to { transform: translate(-40%, -50%) rotate(-360deg); }
  }

  /* Floating petals */
  .petal {
    position: absolute;
    width: 8px;
    height: 12px;
    border-radius: 50% 50% 50% 0;
    opacity: 0;
    animation: petal-fall linear infinite;
  }

  .petal-1 {
    background: rgba(255, 56, 92, 0.15);
    left: 10%;
    animation-duration: 12s;
    animation-delay: 0s;
  }
  .petal-2 {
    background: rgba(146, 23, 77, 0.1);
    left: 25%;
    width: 6px;
    height: 10px;
    animation-duration: 15s;
    animation-delay: 2s;
  }
  .petal-3 {
    background: rgba(70, 4, 121, 0.08);
    left: 45%;
    animation-duration: 18s;
    animation-delay: 5s;
  }
  .petal-4 {
    background: rgba(255, 56, 92, 0.12);
    left: 65%;
    width: 10px;
    height: 14px;
    animation-duration: 14s;
    animation-delay: 1s;
  }
  .petal-5 {
    background: rgba(146, 23, 77, 0.08);
    left: 80%;
    width: 7px;
    height: 11px;
    animation-duration: 16s;
    animation-delay: 7s;
  }
  .petal-6 {
    background: rgba(255, 56, 92, 0.1);
    left: 35%;
    animation-duration: 20s;
    animation-delay: 3s;
  }
  .petal-7 {
    background: rgba(70, 4, 121, 0.06);
    left: 55%;
    width: 9px;
    height: 13px;
    animation-duration: 13s;
    animation-delay: 8s;
  }
  .petal-8 {
    background: rgba(255, 56, 92, 0.08);
    left: 90%;
    width: 6px;
    height: 9px;
    animation-duration: 17s;
    animation-delay: 4s;
  }

  @keyframes petal-fall {
    0% {
      top: -5%;
      opacity: 0;
      transform: rotate(0deg) translateX(0);
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      top: 105%;
      opacity: 0;
      transform: rotate(720deg) translateX(80px);
    }
  }

  /* Content */
  .error-content {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .error-number {
    font-family: Inter, -apple-system, system-ui, sans-serif;
    font-size: clamp(8rem, 20vw, 14rem);
    font-weight: 700;
    letter-spacing: -6px;
    line-height: 1;
    background: linear-gradient(135deg, #222222 0%, #460479 50%, #ff385c 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 8s ease infinite;
    margin-bottom: 1rem;
    user-select: none;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .error-title {
    font-family: Inter, -apple-system, system-ui, sans-serif;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.44px;
    color: #222222;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .error-subtitle {
    font-family: Inter, -apple-system, system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: #6a6a6a;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .vow-counter {
    margin-top: 2rem;
    font-family: Inter, -apple-system, system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    color: #6a6a6a;
    opacity: 0;
    transition: opacity 0.5s ease;
    min-height: 1.2em;
  }

  .vow-counter.visible {
    opacity: 1;
  }

  .error-number {
    cursor: default;
    transition: transform 0.15s ease;
    user-select: none;
  }

  .error-number:active {
    transform: scale(0.97);
  }

  .error-number.wiggle {
    animation: wiggle 0.4s ease;
  }

  @keyframes wiggle {
    0% { transform: rotate(0deg); }
    20% { transform: rotate(-3deg); }
    40% { transform: rotate(3deg); }
    60% { transform: rotate(-2deg); }
    80% { transform: rotate(1deg); }
    100% { transform: rotate(0deg); }
  }

  .error-number.vowed {
    animation: vow-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes vow-pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ring,
    .petal,
    .error-number {
      animation: none;
    }
    .error-number {
      background-position: 0% 50%;
    }
  }
</style>

