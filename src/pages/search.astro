---
import Base from "@/layouts/Base.astro";
import SearchBar from "@/layouts/SearchBar";
import { getSinglePage } from "@/lib/contentParser.astro";
import { plainify, slugify, truncateText } from "@/lib/utils/textConverter";

const directory = await getSinglePage("directory");

const resolveImage = (img: any) =>
  typeof img === 'object' && img?.src ? img.src : typeof img === 'string' ? img : undefined;

const searchList = directory.map((item) => ({
  slug: item.id || slugify(item.data.title),
  data: {
    title: item.data.title,
    description: item.data.description || "",
    image: resolveImage(item.data.image),
    location: item.data.location || [],
    category: item.data.category || [],
    tier: item.data.tier || "registered",
  },
  // Strip markdown and cap body so the search payload stays small. The body
  // only carries weight 0.5 in Fuse — we don't need the full article inlined.
  content: item.body
    ? truncateText(plainify(item.body).replace(/\s+/g, " ").trim(), 600)
    : item.data.description || "",
  type: "directory" as const,
}));
---

<Base
  title="Search"
  meta_title="Search Australian Wedding Celebrants"
  description={`Search ${searchList.length} celebrants by name, location, or specialty.`}
>
  <section class="py-16 md:py-20">
    <div class="container max-w-3xl">
      <div class="text-center mb-10">
        <h1 style="font-weight: 700; letter-spacing: -0.44px;">Search</h1>
        <p class="text-light mt-3" style="font-weight: 400;">
          Find celebrants by name, location, or specialty —
          searching {searchList.length} celebrants across Australia.
        </p>
      </div>
      <SearchBar client:idle searchList={searchList} />
    </div>
  </section>
</Base>
