---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import DirectoryListingsWrapper from "../components/DirectoryListingsWrapper.astro";
import TierIcon from "@/components/TierIcon.astro";
---

<Base>
  {/* Hero section */}
  <section class="hero-section relative overflow-hidden text-center">

    {/* Content */}
    <div class="container relative z-10 py-20 md:py-32">
      <div class="hero-content">
        <h1 class="text-h2-sm md:text-h1 mb-4" style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.15; color: #86244c;">
          Find Your Perfect<br class="hidden sm:block" /> Wedding Celebrant
        </h1>
        <p class="text-lg max-w-2xl mx-auto mb-10" style="font-weight: 500; line-height: 1.6; color: #444444;">
          Australia's quality-rated directory of professional wedding celebrants — recognising and celebrating proven professionalism
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/directory/" class="btn btn-primary px-8 py-3 no-underline">
            Browse Celebrants
          </a>
          <a href="/tiers/" class="btn btn-outline-primary px-8 py-3 no-underline">
            Our Standards
          </a>
        </div>
      </div>

      {/* Tier pills — floating below the CTA */}
      <div class="mt-12 flex flex-wrap items-center justify-center gap-3">
        <a href="/registered/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs border border-border bg-white/80 text-light no-underline hover:border-dark hover:text-dark hover:bg-white transition-all duration-200" style="font-weight: 500; backdrop-filter: blur(4px);">
          Registered
        </a>
        <a href="/endorsed/" class="pill-endorsed inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs no-underline transition-all duration-200" style="font-weight: 600;">
          <TierIcon tier="endorsed" />
          Endorsed
        </a>
        <a href="/luminaries/" class="pill-luminary inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs no-underline transition-all duration-200" style="font-weight: 600;">
          <TierIcon tier="luminary" />
          Luminary
        </a>
      </div>
    </div>
  </section>

  {/* Our Standards section */}
  <section class="py-16 md:py-20 border-t border-border bg-theme-light">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="mb-3" style="font-weight: 700; letter-spacing: -0.44px;">
          Recognising Professional Excellence
        </h2>
        <p class="text-light max-w-2xl mx-auto" style="font-weight: 400; line-height: 1.6;">
          This isn't an awards process — it's a recognition system. When celebrants prove they've gone above and beyond through documented experience, qualifications, and industry support, we celebrate that achievement. Each tier reflects a real level of professionalism you can trust.
        </p>
      </div>

      <div class="flex flex-wrap gap-8 justify-center">
        {/* Registered */}
        <div class="w-full sm:w-[calc(50%-1rem)] md:w-[calc(33.333%-1.34rem)]">
          <div class="bg-white rounded-card p-6 h-full border border-border">
            <div class="inline-flex items-center gap-2 text-light px-3 py-1 rounded-full text-xs border border-border mb-4" style="font-weight: 500;">
              Registered
            </div>
            <h3 class="text-base mb-2" style="font-weight: 600; letter-spacing: -0.18px;">Registered Celebrant</h3>
            <p class="text-light text-sm" style="font-weight: 400; line-height: 1.6;">
              Commonwealth authorised marriage celebrant with a complete professional profile.
            </p>
          </div>
        </div>

        {/* Endorsed */}
        <div class="w-full sm:w-[calc(50%-1rem)] md:w-[calc(33.333%-1.34rem)]">
          <div class="bg-white rounded-card p-6 h-full border-2" style="border-color: #92174d;">
            <div class="inline-flex items-center gap-2 text-white px-3 py-1 rounded-full text-xs mb-4" style="font-weight: 600; background: #92174d;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              Endorsed
            </div>
            <h3 class="text-base mb-2" style="font-weight: 600; letter-spacing: -0.18px;">Endorsed Celebrant</h3>
            <p class="text-light text-sm" style="font-weight: 400; line-height: 1.6;">
              3+ years experience, qualified, insured, with 5+ verified reviews, 100+ ceremonies, and documented professional development.
            </p>
          </div>
        </div>

        {/* Luminary */}
        <div class="w-full sm:w-[calc(50%-1rem)] md:w-[calc(33.333%-1.34rem)]">
          <div class="bg-white rounded-card p-6 h-full border-2" style="border-color: #460479;">
            <div class="inline-flex items-center gap-2 text-white px-3 py-1 rounded-full text-xs mb-4" style="font-weight: 600; background: #460479;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
              Luminary
            </div>
            <h3 class="text-base mb-2" style="font-weight: 600; letter-spacing: -0.18px;">Luminary Celebrant</h3>
            <p class="text-light text-sm" style="font-weight: 400; line-height: 1.6;">
              7+ years, 20+ couple reviews, 10+ vendor reviews, industry awards, and demonstrated leadership. The very best in the profession.
            </p>
          </div>
        </div>
      </div>

      <div class="text-center mt-10">
        <a href="/tiers/" class="text-sm text-dark hover:text-primary no-underline" style="font-weight: 500; text-decoration: underline; text-underline-offset: 3px;">
          Learn more about our standards
        </a>
      </div>
    </div>
  </section>

  {/* Directory listings */}
  <section class="py-16 md:py-24">
    <div class="container">
      <DirectoryListingsWrapper
        title="Australia's Top Wedding Celebrants"
        sortBy="random"
        featuredOnly={false}
        showFilters={true}
        maxItems={32}
      />
    </div>
  </section>
</Base>

<style>
  .hero-section {
    background-color: #FFEDEF;
    background-image: url("/hero-bg.svg");
    background-size: cover;
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* No entrance animation — content appears immediately with the background */
</style>
