---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import DirectoryItem from "@/components/DirectoryItem.astro";

const allItems = await getSinglePage("directory");
const tierOrder = { luminary: 0, endorsed: 1, registered: 2 };
const items = allItems
  .filter(item => item.data.australia_wide === true);
// Fisher-Yates shuffle first for fair random ordering
for (let i = items.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [items[i], items[j]] = [items[j], items[i]];
}
// Stable sort by tier priority (preserves random order within each tier)
items.sort((a, b) => {
  const tierA = tierOrder[a.data.tier || "registered"] ?? 2;
  const tierB = tierOrder[b.data.tier || "registered"] ?? 2;
  return tierA - tierB;
});
---

<Base title="Australia Wide Wedding Celebrants" meta_title="Australia Wide Wedding Celebrants — Australian Wedding Celebrants" description="Wedding celebrants who travel Australia wide. No matter where in Australia you're getting married, these celebrants will be there.">
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="text-center mb-12">
        <div class="pill-dark inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm mb-4" style="font-weight: 600;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Australia Wide
        </div>
        <h1 class="mb-4" style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.2;">
          Australia Wide Wedding Celebrants
        </h1>
        <p class="text-light max-w-2xl mx-auto" style="font-weight: 400; line-height: 1.6;">
          These celebrants travel anywhere in Australia for your wedding. No matter where you're saying "I do", they'll be there. {items.length} celebrant{items.length !== 1 ? "s" : ""} available Australia wide.
        </p>
      </div>

      <div class="masonry-grid">
        {items.map((item, index) => (
          <DirectoryItem item={item} isFirst={index === 0} />
        ))}
      </div>

      {items.length === 0 && (
        <div class="text-center py-16">
          <p class="text-light text-lg">No Australia wide celebrants listed yet. <a href="/contact/" class="text-dark underline">Contact us</a> if you travel nationally.</p>
        </div>
      )}

      <div class="text-center mt-12">
        <a href="/directory/" class="btn btn-outline-primary no-underline">View All Celebrants</a>
      </div>
    </div>
  </section>
</Base>
