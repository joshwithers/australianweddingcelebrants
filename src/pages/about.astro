---
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getEntry, render } from "astro:content";

const entry = (await getEntry("about", "-index")) as CollectionEntry<"about">;
const { Content } = await render(entry);
const { title, meta_title, image, what_i_do } = entry.data;
---

<Base title={title} meta_title={meta_title} image={image}>
  <section class="py-16 md:py-20">
    <div class="container">
      <div class="row md:gx-5">
        <div class="sm:col-5 md:col-4">
          {
            image && (
              <div class="mb-8">
                <Image
                  src={image}
                  width={295}
                  height={395}
                  alt={title}
                  class="w-full"
                />
              </div>
            )
          }
        </div>
        <div class="sm:col-7 md:col-8">
          <h1 set:html={markdownify(title)} class="mb-6" style="font-weight: 700; letter-spacing: -0.44px;" />

          <div class="content">
            <Content />
          </div>
          <div class="flex flex-wrap gap-3 mt-8">
            <a href="/tiers/" class="btn btn-primary no-underline">
              Our Standards
            </a>
            <a href="/contact/" class="btn btn-outline-primary no-underline">
              Get In Touch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 border-t border-border bg-theme-light">
    <div class="container">
      <div class="text-center mb-12">
        <h2 style="font-weight: 600; letter-spacing: -0.44px;">{what_i_do.title}</h2>
      </div>
      <div class="row justify-center gy-4">
        {
          what_i_do.items.map((item: any) => (
            <div class="lg:col-4 md:col-6">
              <div class="bg-white rounded-card p-6 h-full" style="box-shadow: rgba(0,0,0,0.02) 0px 0px 0px 1px, rgba(0,0,0,0.04) 0px 2px 6px, rgba(0,0,0,0.1) 0px 4px 8px;">
                <h4 class="text-dark mb-3" style="font-weight: 600; letter-spacing: -0.18px;">{item.title}</h4>
                <p class="text-light text-sm" style="font-weight: 400; line-height: 1.6;">{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
