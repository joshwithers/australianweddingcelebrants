---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import DirectoryItem from "@/components/DirectoryItem.astro";

const allItems = await getSinglePage("directory");
const items = allItems
  .filter(item => (item.data.tier || "registered") === "endorsed");
// Fisher-Yates shuffle for fair random ordering
for (let i = items.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [items[i], items[j]] = [items[j], items[i]];
}
---

<Base title="Endorsed Celebrants" meta_title="Endorsed Celebrants — Australian Wedding Celebrants" description="Browse all Endorsed celebrants — professionals who've proven 3+ years experience, formal qualifications, insurance, 5+ verified reviews, and 100+ ceremonies performed.">
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 text-white px-4 py-1.5 rounded-full text-sm mb-4" style="font-weight: 600; background: #92174d;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
          Endorsed
        </div>
        <h1 class="mb-4" style="font-weight: 700; letter-spacing: -0.44px; line-height: 1.2;">
          Endorsed Celebrants
        </h1>
        <p class="text-light max-w-2xl mx-auto" style="font-weight: 400; line-height: 1.6;">
          These celebrants have submitted documented proof of at least 3 years' experience, formal qualifications, professional indemnity insurance, ongoing professional development, 5+ verified reviews, and 100+ ceremonies performed. {items.length} celebrants endorsed.
        </p>
      </div>

      <div class="masonry-grid">
        {items.map((item, index) => (
          <DirectoryItem item={item} isFirst={index === 0} />
        ))}
      </div>

      {items.length === 0 && (
        <div class="text-center py-16">
          <p class="text-light text-lg">No endorsed celebrants yet. <a href="/contact/" class="text-dark underline">Submit your documentation</a> to be the first.</p>
        </div>
      )}

      <div class="text-center mt-12">
        <a href="/directory/" class="btn btn-outline-primary no-underline">View All Celebrants</a>
      </div>
    </div>
  </section>
</Base>
