<style>
  .logo-full {
    display: none;
    height: 28px;
    width: auto;
  }

  .logo-compact {
    display: block;
    height: 28px;
    width: auto;
  }

  @media (min-width: 540px) {
    .logo-full {
      display: block;
      height: 30px;
    }
