---
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import { markdownify } from "@/lib/utils/textConverter";
---

<footer class="border-t border-border bg-theme-light">
  <div class="container py-12">
    <div class="flex flex-col gap-8">
      {/* Top row: email + copyright */}
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <nav>
          <ul class="flex flex-wrap items-center justify-center md:justify-start gap-x-6 gap-y-2">
            {
              menu.footer.map((item) => (
                <li>
                  <a href={item.url} class="text-sm text-light hover:text-dark transition-colors duration-200 no-underline" style="font-weight: 500;">
                    {item.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <p set:html={markdownify(config.params.copyright)} class="text-sm text-light text-center md:text-right" style="font-weight: 400;" />
      </div>

      {/* Dev credit */}
      <div class="flex items-center justify-center gap-4 pt-4 border-t border-border/50">
        <p class="dev-credit text-xs text-light tracking-wide" style="font-weight: 400;">
          Another
          <a href="https://unpopular.au" target="_blank" rel="noopener noreferrer" class="dev-credit-link no-underline" style="font-weight: 500;">
            Unpopular
          </a>
          website on
          <a href="https://theinternet.com.au" target="_blank" rel="noopener noreferrer" class="dev-credit-link no-underline" style="font-weight: 500;">
            The Internet
          </a>
        </p>
        <a href="https://github.com/joshwithers/australianweddingcelebrants" target="_blank" rel="noopener noreferrer" aria-label="View source on GitHub" class="text-light hover:text-dark transition-colors duration-200">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .dev-credit {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 10px;
  }

  .dev-credit-link {
    color: inherit;
    position: relative;
    transition: color 0.3s ease;
  }

  .dev-credit-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: #222222;
    transition: width 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .dev-credit:hover .dev-credit-link {
    color: #222222;
  }

  .dev-credit-link:hover::after {
    width: 100%;
  }

  .dev-credit-link:hover {
    color: #222222;
  }
</style>
