---
import Logo from "../components/Logo.astro";
import menu from "../../config/menu.json";

export interface ChildNavigationLink {
  name: string;
  url: string;
}

export interface NavigationLink {
  name: string;
  url: string;
  hasChildren?: boolean;
  children?: ChildNavigationLink[];
}

const { main }: { main: NavigationLink[] } = menu;
---

<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-dark focus:text-white focus:px-4 focus:py-2 focus:rounded-btn focus:text-sm"
  style="font-weight: 500;"
>
  Skip to content
</a>
<header class="header sticky top-0 z-50 bg-white border-b border-border/50">
  <nav class="navbar container py-4" aria-label="Primary">
    <div class="order-0">
      <Logo />
    </div>

    <button
      id="nav-toggle"
      type="button"
      class="nav-toggle order-2 flex cursor-pointer items-center text-dark md:hidden"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Toggle navigation menu"
    >
      <svg class="nav-icon nav-icon--open h-5 w-5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z" />
      </svg>
      <svg class="nav-icon nav-icon--close h-5 w-5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"
        />
      </svg>
    </button>

    <ul
      id="nav-menu"
      class="navbar-nav order-3 hidden w-full md:order-1 md:flex md:w-auto md:items-center"
    >
      {
        main.map((menu) => (
          <>
            {menu.hasChildren ? (
              <li class="nav-item nav-dropdown group relative cursor-pointer">
                <span class="nav-link inline-flex items-center">
                  {menu.name}
                  <svg class="h-4 w-4 fill-current ml-1" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z" />
                  </svg>
                </span>
                <ul class="nav-dropdown-list hidden group-hover:block md:invisible md:absolute md:block md:opacity-0 md:group-hover:visible md:group-hover:opacity-100">
                  {menu.children?.map((child) => (
                    <li class="nav-dropdown-item">
                      <a href={child.url} class="nav-dropdown-link">
                        {child.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li class="nav-item">
                <a href={menu.url} class="nav-link block">
                  {menu.name}
                </a>
              </li>
            )}
          </>
        ))
      }
    </ul>

    <div class="order-1 ml-auto flex items-center md:order-2 md:ml-0">
      <a
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-theme-light text-dark transition-colors duration-200 hover:text-primary"
        href="/search/"
        title="Search"
        aria-label="Search"
      >
        <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
          <path d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0S416 93.1 416 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z" />
        </svg>
      </a>
    </div>
  </nav>
</header>

<script>
  // Toggle mobile navigation open/closed. Re-binds on every ClientRouter navigation.
  const bindNavToggle = () => {
    const toggle = document.getElementById("nav-toggle");
    const menu = document.getElementById("nav-menu");
    if (!toggle || !menu) return;

    const close = () => toggle.setAttribute("aria-expanded", "false");

    toggle.addEventListener("click", () => {
      const open = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", open ? "false" : "true");
    });

    // Close on Escape for keyboard users.
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        close();
        toggle.focus();
      }
    });
  };

  bindNavToggle();
  document.addEventListener("astro:page-load", bindNavToggle);
</script>
