---
import config from "../config/config.json";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import type { ImageMetadata } from "astro";
import { plainify, truncateText } from "../lib/utils/textConverter";
import Footer from "./partials/Footer.astro";
import Header from "./partials/Header.astro";
import "../styles/main.css";

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string | ImageMetadata;
  noindex?: boolean;
  canonical?: string;
  /** OpenGraph object type — "website" (default), "profile" for celebrant pages, etc. */
  og_type?: string;
  /** Optional hex colour applied to the body background so the translucent header picks it up. */
  page_bg?: string;
  /** Mobile browser chrome colour. Defaults to page_bg, then to white. Match the
   *  page's top-of-page colour so the URL bar feels seamless on Safari/Chrome mobile. */
  theme_color?: string;
}

const {
  title,
  meta_title,
  description,
  image: rawImage,
  noindex,
  canonical,
  og_type = "website",
  page_bg,
  theme_color,
} = Astro.props;

// Browser chrome colour — explicit override > page bg > white.
const themeColor = theme_color || page_bg || "#ffffff";

// Resolve image to string (local images are objects with .src)
const image = typeof rawImage === "object" && rawImage?.src ? rawImage.src : rawImage;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <!-- favicon -->
    <link rel="icon" type="image/svg+xml" href={config.site.favicon} />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- title -->
    <title>
      {plainify(meta_title ? meta_title : title ? title : config.site.title)}
    </title>

    <!-- canonical url -->
    <link rel="canonical" href={canonical || `${config.site.base_url}${Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '') + '/'}`} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- meta-description -->
    <meta
      name="description"
      content={truncateText(plainify(
        description ? description : config.metadata.meta_description
      ), 160)}
    />

    <Font
      cssVariable="--font-inter"
      preload={[
        { weight: 400, style: "normal", subset: "latin" },
        { weight: 700, style: "normal", subset: "latin" }
      ]}
    />

    <ClientRouter />

    <!-- theme meta -->
    <meta name="theme-color" content={themeColor} />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="author" content={config.metadata.meta_author} />

    <!-- Open Graph -->
    <meta property="og:title" content={plainify(meta_title ? meta_title : title ? title : config.site.title)} />
    <meta property="og:description" content={truncateText(plainify(description ? description : config.metadata.meta_description), 160)} />
    <meta property="og:type" content={og_type} />
    <meta property="og:url" content={canonical || `${config.site.base_url}${Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '') + '/'}`} />
    <meta property="og:image" content={image && typeof image === 'string' && image.startsWith('http') ? image : `${config.site.base_url}${image || config.metadata.meta_image}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={plainify(meta_title ? meta_title : title ? title : config.site.title)} />
    <meta name="twitter:description" content={truncateText(plainify(description ? description : config.metadata.meta_description), 160)} />
    <meta name="twitter:image" content={image && typeof image === 'string' && image.startsWith('http') ? image : `${config.site.base_url}${image || config.metadata.meta_image}`} />

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": config.site.title,
      "url": config.site.base_url,
      "description": truncateText(plainify(description ? description : config.metadata.meta_description), 160),
      "publisher": {
        "@type": "Organization",
        "name": config.site.title,
        "url": config.site.base_url
      },
      "inLanguage": "en-AU",
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${config.site.base_url}/search/?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    })} />

  </head>
  <body
    data-page={Astro.url.pathname === "/" ? "home" : undefined}
    data-page-bg={page_bg ? "" : undefined}
    style={page_bg ? `background-color: ${page_bg}; --page-bg: ${page_bg};` : undefined}
  >
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
