---
import { Image } from "astro:assets";
import { humanize, slugify } from "@/lib/utils/textConverter";
import TierBadge from "./TierBadge.astro";
import externalImageDimensions from "@/data/external-image-dimensions.json";

const { item, isFirst = false } = Astro.props;
const tier = item.data.tier || "registered";
const itemSlug = item.id || item.slug || slugify(item.data.title);

// Show the most recent award as a corner marker; tooltip carries the full title.
const topAward = Array.isArray(item.data.awards) && item.data.awards.length > 0
  ? [...item.data.awards].sort((a: any, b: any) => b.year - a.year)[0]
  : null;
const topAwardLabel = topAward
  ? [topAward.title, topAward.region, topAward.year].filter(Boolean).join(" — ")
  : "";

// Look up pre-probed dimensions for external image URLs (populated by
// scripts/probe-external-images.mjs). Falls back to undefined when the
// URL hasn't been probed or the probe failed.
const externalDims =
  typeof item.data.image === "string"
    ? (externalImageDimensions as Record<string, { width: number; height: number }>)[item.data.image]
    : undefined;
---

<div class="directory-card-shell">
  <div class="directory-card group relative rounded-card bg-white transition-shadow duration-300" data-tier={tier}>
    {/* Photography hero — natural aspect ratio, no cropping. External URLs
        use pre-probed dimensions (see scripts/probe-external-images.mjs) so
        the browser reserves correct aspect-ratio space and PageSpeed doesn't
        flag declared/actual mismatches. */}
    {item.data.image && (
      <div class="directory-card-image-wrap relative overflow-hidden" style="border-radius: var(--radius-card) var(--radius-card) 0 0;">
        {typeof item.data.image === "string" ? (
          <img
            src={item.data.image}
            alt={item.data.title}
            width={externalDims?.width}
            height={externalDims?.height}
            class="directory-card-img w-full group-hover:scale-[1.03] transition-transform duration-500"
            loading={isFirst ? "eager" : "lazy"}
            decoding={isFirst ? "sync" : "async"}
            fetchpriority={isFirst ? "high" : undefined}
          />
        ) : (
          <Image
            src={item.data.image}
            alt={item.data.title}
            width={600}
            class="directory-card-img w-full group-hover:scale-[1.03] transition-transform duration-500"
            loading={isFirst ? "eager" : "lazy"}
            decoding={isFirst ? "sync" : "async"}
            fetchpriority={isFirst ? "high" : undefined}
            sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
            quality={isFirst ? 90 : 80}
            format="webp"
          />
        )}
        <TierBadge tier={tier} />
        {topAward && (
          <span class="award-marker" title={topAwardLabel} aria-label={topAwardLabel}>
            <span aria-hidden="true">{topAward.emoji || "🏆"}</span>
          </span>
        )}
      </div>
    )}

    {/* Card details */}
    <div class="p-4">
      <div class="flex gap-3 mb-2 justify-center">
        {(tier === "luminary" || tier === "endorsed") && item.data.logo ? (
          <div class="directory-card-logo" style="width: 90%; display: flex; justify-content: center;">
            {typeof item.data.logo === "string" ? (
              <img
                src={item.data.logo}
                alt={item.data.title}
                class="max-w-full max-h-24 h-auto w-auto"
                loading="lazy"
              />
            ) : (
              <Image
                src={item.data.logo}
                alt={item.data.title}
                width={400}
                class="max-w-full max-h-24 h-auto w-auto"
                loading="lazy"
                format="webp"
              />
            )}
          </div>
        ) : (
          <h2 class="text-base text-dark m-0 text-center" style="font-weight: 600; letter-spacing: -0.18px; line-height: 1.25;">
            {item.data.title}
          </h2>
        )}
      </div>

      {item.data.location && item.data.location.length > 0 && (
        <p class="text-sm text-light mb-2 text-center" style="font-weight: 600;">
          {item.data.location.map((loc: string) => humanize(loc)).join(" · ")}
        </p>
      )}

      {item.data.description && (
        <p class="text-sm text-light mb-3 line-clamp-2" style="font-weight: 400;">
          {item.data.description}
        </p>
      )}

      <div class="flex flex-wrap gap-1.5">
        {item.data.category.map((cat: string) => (
          <span class="bg-theme-light text-dark px-2 py-0.5 rounded-badge text-xs" style="font-weight: 500;">
            {humanize(cat)}
          </span>
        ))}
      </div>
      {(item.data.australia_wide || item.data.international) && (
        <div class="flex flex-wrap gap-2 mt-3">
          {item.data.australia_wide && (
            <a href="/australia-wide/" class="badge-link px-3 py-2 rounded-badge text-xs inline-flex items-center gap-1.5 no-underline transition-all" style="font-weight: 500; background: #e8e8e8; color: #444; min-height: 32px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              Australia Wide
            </a>
          )}
          {item.data.international && (
            <a href="/destination-wedding-celebrants/" class="badge-link px-3 py-2 rounded-badge text-xs inline-flex items-center gap-1.5 no-underline transition-all" style="font-weight: 500; background: #e8e8e8; color: #444; min-height: 32px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path d="M7 3.34V5a3 3 0 0 0 3 3a2 2 0 0 1 2 2c0 1.1.9 2 2 2a2 2 0 0 0 2-2c0-1.1.9-2 2-2h3.17"/><path d="M11 21.95V18a2 2 0 0 0-2-2a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/></svg>
              Destination Weddings
            </a>
          )}
        </div>
      )}
    </div>

    {/* Stretched link — makes the whole card clickable */}
    <a href={`/directory/${itemSlug}/`} class="stretched-link" aria-label={item.data.title}></a>
  </div>
</div>

<style>
  .directory-card-shell {
    break-inside: avoid;
    padding-bottom: 1.5rem;
  }

  /* Image wrapper — placeholder bg while image loads */
  .directory-card-image-wrap {
    background: #f0f0f0;
  }

  /* Natural ratio images — height follows source aspect ratio */
  .directory-card-img {
    height: auto !important;
    width: 100%;
    opacity: 0;
    animation: cardImgFadeIn 0.4s ease forwards;
  }

  @keyframes cardImgFadeIn {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .directory-card-img {
      animation: none;
      opacity: 1;
    }
    .directory-card .group-hover\:scale-\[1\.03\] {
      transform: none !important;
    }
  }

  /* Stretched link fills the card */
  .stretched-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  /* Tier badge: stays absolute-positioned over the image, above stretched link */
  .tier-badge {
    z-index: 2;
  }

  /* Award marker — top-right corner emoji pill, above stretched link */
  .award-marker {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    line-height: 1;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(4px);
    box-shadow: rgba(0, 0, 0, 0.08) 0px 2px 6px, rgba(0, 0, 0, 0.04) 0px 0px 0px 1px;
    cursor: help;
  }

  /* Badge links in the card body sit above the stretched link */
  .badge-link {
    position: relative;
    z-index: 2;
  }

  /* Tier-tinted card chrome — subtle coloured shadow + border ring.
     Registered cards stay neutral. Bump the opacity values here if you
     want bolder emphasis for premium tiers. */
  .directory-card[data-tier="registered"] {
    box-shadow:
      rgba(0, 0, 0, 0.04) 0px 0px 0px 1px,
      rgba(0, 0, 0, 0.06) 0px 2px 8px,
      rgba(0, 0, 0, 0.08) 0px 4px 12px;
  }

  .directory-card[data-tier="luminary"] {
    box-shadow:
      rgba(70, 4, 121, 0.24) 0px 0px 0px 1px,
      rgba(0, 0, 0, 0.03) 0px 2px 6px,
      rgba(70, 4, 121, 0.14) 0px 4px 14px;
  }

  .directory-card[data-tier="endorsed"] {
    box-shadow:
      rgba(146, 23, 77, 0.24) 0px 0px 0px 1px,
      rgba(0, 0, 0, 0.03) 0px 2px 6px,
      rgba(146, 23, 77, 0.14) 0px 4px 14px;
  }
</style>
