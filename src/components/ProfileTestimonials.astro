---
// Up to three testimonial quotes. Emits schema.org Review JSON-LD for each.
interface Testimonial {
  quote: string;
  author: string;
  role?: string;
}

interface Props {
  testimonials: Testimonial[];
  subjectName: string;
}

const { testimonials, subjectName } = Astro.props;
const items = testimonials.slice(0, 3);

const reviewSchema = items.map((t) => ({
  "@context": "https://schema.org",
  "@type": "Review",
  "reviewBody": t.quote,
  "author": { "@type": "Person", "name": t.author },
  "itemReviewed": { "@type": "Person", "name": subjectName },
  "reviewRating": { "@type": "Rating", "ratingValue": 5, "bestRating": 5 },
}));
---

{items.length > 0 && (
  <section class="profile-testimonials" aria-label="Testimonials">
    <h2 class="profile-testimonials__heading">
      Kind words from couples
    </h2>
    <div class="profile-testimonials__grid">
      {items.map((t) => (
        <figure class="profile-testimonials__card">
          <svg class="profile-testimonials__mark" width="28" height="24" viewBox="0 0 28 24" fill="currentColor" aria-hidden="true">
            <path d="M0 24V12.48c0-3.52.7-6.4 2.1-8.64C3.5 1.6 5.87.5 9.2.48V4.8c-1.33.32-2.37.99-3.1 2C5.37 7.83 5 9 5 10.32H9V24H0zm16 0V12.48c0-3.52.7-6.4 2.1-8.64C19.5 1.6 21.87.5 25.2.48V4.8c-1.33.32-2.37.99-3.1 2-.73 1.02-1.1 2.2-1.1 3.52H25V24h-9z" />
          </svg>
          <blockquote class="profile-testimonials__quote">
            {t.quote}
          </blockquote>
          <figcaption class="profile-testimonials__attribution">
            <span class="profile-testimonials__author">{t.author}</span>
            {t.role && <span class="profile-testimonials__role">{t.role}</span>}
          </figcaption>
        </figure>
      ))}
    </div>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
  </section>
)}

<style>
  .profile-testimonials {
    display: block;
  }

  .profile-testimonials__heading {
    font-weight: 600;
    letter-spacing: -0.44px;
    margin-bottom: 2rem;
    text-align: center;
  }

  .profile-testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .profile-testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .profile-testimonials__card {
    position: relative;
    margin: 0;
    padding: 2rem 1.75rem;
    background: #fff;
    border-radius: 16px;
    box-shadow: rgba(0, 0, 0, 0.02) 0px 0px 0px 1px, rgba(0, 0, 0, 0.04) 0px 2px 6px, rgba(0, 0, 0, 0.08) 0px 4px 8px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .profile-testimonials__mark {
    color: #ecb6c7;
    flex: none;
  }

  .profile-testimonials__quote {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: #222;
    font-style: normal;
    font-weight: 400;
    flex: 1;
  }

  .profile-testimonials__quote::before,
  .profile-testimonials__quote::after {
    content: "";
  }

  .profile-testimonials__attribution {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 0.75rem;
    border-top: 1px solid #f0f0f0;
  }

  .profile-testimonials__author {
    font-size: 0.875rem;
    font-weight: 600;
    color: #222;
    letter-spacing: -0.1px;
  }

  .profile-testimonials__role {
    font-size: 0.8125rem;
    color: #6a6a6a;
    font-weight: 400;
  }
</style>
